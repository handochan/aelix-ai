{
  "$defs": {
    "ActionDescriptor": {
      "additionalProperties": false,
      "description": "Wire-safe action reference (no function refs cross the wire).\n\nFrontend dispatches ``plugin_action`` events with this descriptor;\nhost routes to the plugin's registered action handler.",
      "properties": {
        "action": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Action",
          "type": "string"
        },
        "confirm": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confirm"
        },
        "payload": {
          "additionalProperties": true,
          "title": "Payload",
          "type": "object"
        },
        "plugin_id": {
          "pattern": "^[a-z][a-z0-9-]{0,63}$",
          "title": "Plugin Id",
          "type": "string"
        }
      },
      "required": [
        "plugin_id",
        "action"
      ],
      "title": "ActionDescriptor",
      "type": "object"
    },
    "AgentMetricPayload": {
      "additionalProperties": false,
      "properties": {
        "delta": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Delta"
        },
        "kind": {
          "const": "agent-metric",
          "default": "agent-metric",
          "title": "Kind",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        },
        "level": {
          "default": "info",
          "enum": [
            "info",
            "success",
            "warning",
            "error"
          ],
          "title": "Level",
          "type": "string"
        },
        "value": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "integer"
            }
          ],
          "title": "Value"
        }
      },
      "required": [
        "label",
        "value"
      ],
      "title": "AgentMetricPayload",
      "type": "object"
    },
    "BreadcrumbPayload": {
      "additionalProperties": false,
      "properties": {
        "href": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Href"
        },
        "icon": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Icon"
        },
        "kind": {
          "const": "breadcrumb",
          "default": "breadcrumb",
          "title": "Kind",
          "type": "string"
        },
        "label": {
          "title": "Label",
          "type": "string"
        }
      },
      "required": [
        "label"
      ],
      "title": "BreadcrumbPayload",
      "type": "object"
    },
    "CommandRoutePayload": {
      "additionalProperties": false,
      "properties": {
        "command": {
          "pattern": "^[a-z][a-z0-9-]*$",
          "title": "Command",
          "type": "string"
        },
        "description": {
          "title": "Description",
          "type": "string"
        },
        "keybind": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Keybind"
        },
        "kind": {
          "const": "command-route",
          "default": "command-route",
          "title": "Kind",
          "type": "string"
        }
      },
      "required": [
        "command",
        "description"
      ],
      "title": "CommandRoutePayload",
      "type": "object"
    },
    "FooterSegmentPayload": {
      "additionalProperties": false,
      "properties": {
        "icon": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Icon"
        },
        "kind": {
          "const": "footer-segment",
          "default": "footer-segment",
          "title": "Kind",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        },
        "tooltip": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Tooltip"
        }
      },
      "required": [
        "text"
      ],
      "title": "FooterSegmentPayload",
      "type": "object"
    },
    "ManagementModalPayload": {
      "additionalProperties": false,
      "properties": {
        "actions": {
          "items": {
            "$ref": "#/$defs/ActionDescriptor"
          },
          "title": "Actions",
          "type": "array"
        },
        "columns": {
          "anyOf": [
            {
              "items": {
                "additionalProperties": true,
                "type": "object"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Columns"
        },
        "command": {
          "pattern": "^[a-z][a-z0-9-]*$",
          "title": "Command",
          "type": "string"
        },
        "fields": {
          "anyOf": [
            {
              "items": {
                "additionalProperties": true,
                "type": "object"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Fields"
        },
        "kind": {
          "const": "management-modal",
          "default": "management-modal",
          "title": "Kind",
          "type": "string"
        },
        "title": {
          "title": "Title",
          "type": "string"
        },
        "view": {
          "enum": [
            "table",
            "grid",
            "form"
          ],
          "title": "View",
          "type": "string"
        }
      },
      "required": [
        "command",
        "title",
        "view"
      ],
      "title": "ManagementModalPayload",
      "type": "object"
    },
    "StatusItemPayload": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "const": "status-item",
          "default": "status-item",
          "title": "Kind",
          "type": "string"
        },
        "level": {
          "default": "info",
          "enum": [
            "info",
            "warning",
            "error"
          ],
          "title": "Level",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "text"
      ],
      "title": "StatusItemPayload",
      "type": "object"
    },
    "ToastPayload": {
      "additionalProperties": false,
      "properties": {
        "auto_dismiss_ms": {
          "anyOf": [
            {
              "maximum": 60000,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": 4000,
          "title": "Auto Dismiss Ms"
        },
        "kind": {
          "const": "toast",
          "default": "toast",
          "title": "Kind",
          "type": "string"
        },
        "level": {
          "default": "info",
          "enum": [
            "info",
            "warning",
            "error",
            "success"
          ],
          "title": "Level",
          "type": "string"
        },
        "text": {
          "title": "Text",
          "type": "string"
        }
      },
      "required": [
        "text"
      ],
      "title": "ToastPayload",
      "type": "object"
    },
    "ToolRendererDescPayload": {
      "additionalProperties": false,
      "properties": {
        "columns": {
          "anyOf": [
            {
              "items": {
                "additionalProperties": true,
                "type": "object"
              },
              "type": "array"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Columns"
        },
        "kind": {
          "const": "tool-renderer-desc",
          "default": "tool-renderer-desc",
          "title": "Kind",
          "type": "string"
        },
        "rows_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Rows Path"
        },
        "text_path": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Text Path"
        },
        "title": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Title"
        },
        "tool_name": {
          "title": "Tool Name",
          "type": "string"
        },
        "view": {
          "enum": [
            "table",
            "grid",
            "form",
            "text"
          ],
          "title": "View",
          "type": "string"
        }
      },
      "required": [
        "tool_name",
        "view"
      ],
      "title": "ToolRendererDescPayload",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "description": "Tier 2 cross-surface descriptor envelope (ADR-0095).",
  "properties": {
    "id": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Id",
      "type": "string"
    },
    "kind": {
      "enum": [
        "footer-segment",
        "status-item",
        "tool-renderer-desc",
        "command-route",
        "breadcrumb",
        "toast",
        "management-modal",
        "agent-metric"
      ],
      "title": "Kind",
      "type": "string"
    },
    "namespace": {
      "pattern": "^[a-z0-9][a-z0-9-]{0,63}$",
      "title": "Namespace",
      "type": "string"
    },
    "payload": {
      "discriminator": {
        "mapping": {
          "agent-metric": "#/$defs/AgentMetricPayload",
          "breadcrumb": "#/$defs/BreadcrumbPayload",
          "command-route": "#/$defs/CommandRoutePayload",
          "footer-segment": "#/$defs/FooterSegmentPayload",
          "management-modal": "#/$defs/ManagementModalPayload",
          "status-item": "#/$defs/StatusItemPayload",
          "toast": "#/$defs/ToastPayload",
          "tool-renderer-desc": "#/$defs/ToolRendererDescPayload"
        },
        "propertyName": "kind"
      },
      "oneOf": [
        {
          "$ref": "#/$defs/FooterSegmentPayload"
        },
        {
          "$ref": "#/$defs/StatusItemPayload"
        },
        {
          "$ref": "#/$defs/ToolRendererDescPayload"
        },
        {
          "$ref": "#/$defs/CommandRoutePayload"
        },
        {
          "$ref": "#/$defs/BreadcrumbPayload"
        },
        {
          "$ref": "#/$defs/ToastPayload"
        },
        {
          "$ref": "#/$defs/ManagementModalPayload"
        },
        {
          "$ref": "#/$defs/AgentMetricPayload"
        }
      ],
      "title": "Payload"
    },
    "removed": {
      "default": false,
      "title": "Removed",
      "type": "boolean"
    }
  },
  "required": [
    "kind",
    "namespace",
    "id",
    "payload"
  ],
  "title": "DescriptorEnvelope",
  "type": "object"
}
