      "properties": {
        "action": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Action",
          "type": "string"
        },
        "confirm": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Confirm"
        },
        "payload": {
          "additionalProperties": true,
          "title": "Payload",
          "type": "object"
        },
        "plugin_id": {
          "pattern": "^[a-z][a-z0-9-]{0,63}$",
          "title": "Plugin Id",
          "type": "string"
        }
      },
      "required": [
        "plugin_id",
        "action"
      ],
      "title": "ActionDescriptor",
      "type": "object"
    },
